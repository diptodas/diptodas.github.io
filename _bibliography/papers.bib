author = {Williams, Louisa Kayah and Awad Alim, Rayan and Sharma, Vishal and Talhouk, Reem and Wong-Villacr\'{e}s, Marisol and Kirabo, Lynn and Harris, Tajanae and Das, Dipto and Maitland, Carleen and Semaan, Bryan and Ahmed, Syed Ishtiaque and Soden, Robert},
title = {HCI, Mobility Justice, and Migration in the Face of Climate Crisis},
year = {2024},
isbn = {9798400711145},
